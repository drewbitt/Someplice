{
	"name": "someplice",
	"version": "0.2.0",
	"private": true,
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"build:deno": "cross-env BUILD_ENV=deno vite build",
		"preview": "vite preview",
		"test:e2e": "playwright test",
		"test:unit": "vitest",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --cache --ignore-path ./config/.prettierignore --check . && eslint -c ./config/eslint.config.js .",
		"format": "prettier --cache --ignore-path ./config/.prettierignore --write .",
		"db:codegen": "kysely-codegen --out-file ./src/lib/types/data.d.ts && prettier --cache --ignore-path ./config/.prettierignore --write ./src/lib/types/data.d.ts",
		"db:migrate": "vite-node ./src/lib/db/migrate-to-latest.ts",
		"db:migrate:single": "vite-node ./src/lib/db/migrate-to-latest.ts --migration"
	},
	"dependencies": {
		"@svelteuidev/composables": "^0.15.7",
		"@svelteuidev/core": "^0.15.7",
		"@trpc/client": "^10.45.2",
		"@trpc/server": "^10.45.2",
		"better-sqlite3": "^11.7.0",
		"croner": "^8.1.2",
		"devalue": "^5.1.1",
		"kysely": "^0.27.5",
		"trpc-sveltekit": "^3.6.2",
		"tslog": "^4.9.3",
		"vite-node": "^2.1.8",
		"zod": "^3.24.1"
	},
	"devDependencies": {
		"@commitlint/cli": "^19.6.0",
		"@commitlint/config-conventional": "^19.6.0",
		"@eslint/js": "^9.16.0",
		"@iconify-json/lucide": "^1.2.18",
		"@ngneat/falso": "^7.2.0",
		"@playwright/test": "^1.49.1",
		"@sveltejs/adapter-node": "^5.2.9",
		"@sveltejs/kit": "^2.10.1",
		"@sveltejs/vite-plugin-svelte": "^3.1.2",
		"@types/better-sqlite3": "^7.6.12",
		"@types/eslint__js": "^8.42.3",
		"@types/node": "^20.17.10",
		"@vite-pwa/sveltekit": "^0.6.6",
		"autoprefixer": "^10.4.20",
		"cross-env": "^7.0.3",
		"daisyui": "^4.12.20",
		"eslint": "^9.16.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-svelte": "^2.46.1",
		"globals": "^15.13.0",
		"kysely-codegen": "^0.17.0",
		"postcss": "^8.4.49",
		"postcss-load-config": "^6.0.1",
		"prettier": "^3.4.2",
		"prettier-plugin-svelte": "^3.3.2",
		"prettier-plugin-tailwindcss": "^0.6.9",
		"svelte": "^4.2.19",
		"svelte-check": "^4.1.1",
		"svelte-dnd-action": "^0.9.52",
		"svelte-preprocess": "^6.0.3",
		"sveltekit-adapter-deno": "^0.16.1",
		"tailwindcss": "^3.4.16",
		"tslib": "^2.8.1",
		"typescript": "^5.7.2",
		"typescript-eslint": "^8.18.0",
		"unplugin-icons": "^0.21.0",
		"vite": "^5.4.11",
		"vite-plugin-pwa": "^0.21.1",
		"vitest": "^2.1.8"
	},
	"type": "module",
	"packageManager": "pnpm@9.15.0"
}
