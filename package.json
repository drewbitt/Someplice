{
	"name": "someplice",
	"version": "0.2.0",
	"private": true,
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"build:deno": "cross-env BUILD_ENV=deno vite build",
		"preview": "vite preview",
		"test:e2e": "playwright test",
		"test:unit": "vitest",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --cache --ignore-path ./config/.prettierignore --check . && eslint -c ./config/eslint.config.js .",
		"format": "prettier --cache --ignore-path ./config/.prettierignore --write .",
		"db:codegen": "kysely-codegen --out-file ./src/lib/types/data.d.ts && prettier --cache --ignore-path ./config/.prettierignore --write ./src/lib/types/data.d.ts",
		"db:migrate": "vite-node ./src/lib/db/migrate-to-latest.ts",
		"db:migrate:single": "vite-node ./src/lib/db/migrate-to-latest.ts --migration"
	},
	"dependencies": {
		"@trpc/client": "^11.18.0",
		"@trpc/server": "^11.18.0",
		"better-sqlite3": "^12.11.1",
		"croner": "^10.0.1",
		"devalue": "^5.8.2",
		"kysely": "^0.29.4",
		"tslog": "^4.11.0",
		"vite-node": "^6.0.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@commitlint/cli": "^21.2.1",
		"@commitlint/config-conventional": "^21.2.0",
		"@eslint/js": "^10.0.1",
		"@iconify-json/lucide": "^1.2.118",
		"@ngneat/falso": "^8.0.2",
		"@playwright/test": "^1.61.1",
		"@sveltejs/adapter-node": "^5.5.7",
		"@sveltejs/kit": "^2.70.1",
		"@sveltejs/vite-plugin-svelte": "^7.2.0",
		"@tailwindcss/postcss": "^4.3.3",

		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "^24.13.3",
		"@vite-pwa/sveltekit": "^1.1.0",
		"cross-env": "^10.1.0",
		"daisyui": "^5.7.0",
		"eslint": "^10.7.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.22.0",
		"globals": "^17.7.0",
		"kysely-codegen": "^0.20.0",
		"prettier": "^3.9.5",
		"prettier-plugin-svelte": "^3.5.2",
		"prettier-plugin-tailwindcss": "^0.8.1",
		"svelte": "^5.56.7",
		"svelte-check": "^4.7.3",
		"svelte-dnd-action": "^0.9.74",
		"sveltekit-adapter-deno": "^0.16.1",
		"tailwindcss": "^4.3.3",
		"tslib": "^2.8.1",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.65.0",
		"unplugin-icons": "^23.0.1",
		"vite": "^8.1.5",
		"vite-plugin-pwa": "^1.3.0",
		"vitest": "^4.1.10",
		"workbox-build": "^7.4.1",
		"workbox-window": "^7.4.1"
	},
	"type": "module",
	"packageManager": "pnpm@10.34.5",
	"pnpm": {
		"onlyBuiltDependencies": [
			"better-sqlite3"
		]
	}
}
